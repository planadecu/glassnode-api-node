# Glassnode API Key (obtain from https://docs.glassnode.com/basic-api/api-key)
# Used by the free-API examples (metadata.validation.ts, metric.dump.ts, bulk.market-cap.ts).
GLASSNODE_API_KEY=your_api_key_here

# --- x402 paid-API example (ex.x402.active-addresses.ts) ---
# No API key needed — you pay per call in USDC on Base.
X402_PRIVATE_KEY=0xyour_funded_wallet_private_key
X402_MAX_PAYMENT=0.06                 # per-call USDC ceiling (metrics cost $0.05, metadata $0.01)
X402_API_URL=https://x402.glassnode.com   # x402 endpoint (mainnet); point elsewhere to use another