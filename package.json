{
  "name": "glassnode-api",
  "version": "0.2.0",
  "description": "JavaScript client for the Glassnode API (Node.js and Browser)",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "browser": "dist/glassnode-api.umd.min.js",
  "module": "dist/glassnode-api.esm.min.js",
  "files": [
    "dist/*.js",
    "dist/*.d.ts",
    "dist/glassnode-api.*.min.js",
    "dist/glassnode-api.*.min.js.map",
    "dist/types"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/planadecu/glassnode-api.git"
  },
  "scripts": {
    "build": "tsc",
    "build:browser": "rollup -c",
    "test": "jest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "prepare": "husky",
    "prepublishOnly": "npm run build && npm run build:browser",
    "preversion": "npm run lint",
    "version": "npm run format && git add -A src",
    "postversion": "git push && git push --tags"
  },
  "author": "Jordi Planadecursach",
  "license": "MIT",
  "dependencies": {
    "zod": "^4.0.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.31.0",
    "@rollup/plugin-commonjs": "^28.0.6",
    "@rollup/plugin-node-resolve": "^16.0.1",
    "@rollup/plugin-typescript": "^12.1.4",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.0.14",
    "eslint": "^9.31.0",
    "husky": "^9.1.7",
    "jest": "^30.0.4",
    "lint-staged": "^16.1.2",
    "prettier": "^3.6.2",
    "rollup": "^4.45.1",
    "@rollup/plugin-terser": "^0.4.4",
    "ts-jest": "^29.4.0",
    "tslib": "^2.8.1",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.37.0"
  },
  "lint-staged": {
    "*.{js,ts,mjs}": [
      "eslint --fix",
      "prettier --write",
      "jest --findRelatedTests --passWithNoTests"
    ]
  }
}
