{
  "name": "glassnode-api",
  "version": "0.6.2",
  "description": "Typescript client for the Glassnode API (Node.js and Browser)",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "browser": "dist/glassnode-api.umd.min.js",
  "module": "dist/glassnode-api.esm.min.js",
  "files": [
    "dist/*.js",
    "dist/*.d.ts",
    "dist/glassnode-api.*.min.js",
    "dist/glassnode-api.*.min.js.map",
    "dist/types"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/planadecu/glassnode-api.git"
  },
  "scripts": {
    "build": "tsc",
    "build:browser": "rollup -c",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "lint": "eslint .",
    "format": "prettier --write .",
    "prepare": "husky",
    "prepublishOnly": "pnpm run build && pnpm run build:browser",
    "preversion": "pnpm run lint",
    "version": "pnpm run format && git add -A src",
    "postversion": "git push && git push --tags"
  },
  "author": "Jordi Planadecursach",
  "license": "MIT",
  "dependencies": {
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.12.0",
    "eslint": "^10.0.3",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "lint-staged": "^16.3.2",
    "prettier": "^3.8.1",
    "rollup": "^4.59.0",
    "@rollup/plugin-terser": "^1.0.0",
    "ts-jest": "^29.4.6",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0"
  },
  "lint-staged": {
    "*.{js,ts,mjs}": [
      "eslint --fix",
      "prettier --write",
      "jest --findRelatedTests --passWithNoTests"
    ]
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "unrs-resolver"
    ]
  }
}
