{
  "name": "glassnode-api",
  "version": "0.7.6",
  "description": "Typescript client for the Glassnode API (Node.js and Browser)",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "browser": "dist/glassnode-api.umd.min.js",
  "module": "dist/glassnode-api.esm.min.js",
  "files": [
    "dist/*.js",
    "dist/*.d.ts",
    "dist/glassnode-api.*.min.js",
    "dist/glassnode-api.*.min.js.map",
    "dist/types"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/planadecu/glassnode-api-node.git"
  },
  "bugs": {
    "url": "https://github.com/planadecu/glassnode-api-node/issues"
  },
  "scripts": {
    "build": "tsc",
    "build:browser": "rollup -c",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "format": "prettier --write .",
    "prepare": "husky",
    "prepublishOnly": "pnpm run build && pnpm run build:browser",
    "preversion": "pnpm run lint",
    "version": "pnpm run format && git add -A src",
    "postversion": "git push && git push --tags"
  },
  "keywords": [
    "glassnode",
    "api",
    "client",
    "typescript",
    "javascript",
    "node",
    "browser",
    "crypto",
    "on-chain",
    "data",
    "analytics",
    "financial",
    "market",
    "indicators",
    "metrics"
  ],
  "author": {
    "name": "Jordi Planadecursach",
    "email": "jordi.planadecusach@glassnode.com",
    "url": "https://github.com/planadecu/glassnode-api-node/"
  },
  "license": "MIT",
  "packageManager": "pnpm@10.32.1",
  "homepage": "https://github.com/planadecu/glassnode-api-node#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "sideEffects": false,
  "exports": {
    ".": {
      "import": "./dist/glassnode-api.esm.min.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./x402": {
      "types": "./dist/x402.d.ts",
      "import": "./dist/x402.js",
      "require": "./dist/x402.js"
    }
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public",
    "tag": "latest",
    "provenance": true
  },
  "dependencies": {
    "zod": "^4.4.3"
  },
  "peerDependencies": {
    "@x402/fetch": ">=2.18.0",
    "@x402/evm": ">=2.18.0",
    "viem": "^2.48.11"
  },
  "peerDependenciesMeta": {
    "@x402/fetch": { "optional": true },
    "@x402/evm": { "optional": true },
    "viem": { "optional": true }
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@rollup/plugin-commonjs": "^29.0.3",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "^4.1.10",
    "@x402/evm": "^2.18.0",
    "@x402/fetch": "^2.18.0",
    "eslint": "^10.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.5",
    "rollup": "^4.62.2",
    "tslib": "^2.8.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0",
    "viem": "^2.55.2",
    "vitest": "^4.1.10"
  },
  "lint-staged": {
    "*.{js,ts,mjs}": [
      "eslint --fix",
      "prettier --write",
      "vitest related --run"
    ]
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "unrs-resolver"
    ],
    "overrides": {
      "serialize-javascript": ">=7.0.5",
      "picomatch": ">=4.0.4",
      "flatted": ">=3.4.2",
      "brace-expansion@5": ">=5.0.6"
    }
  }
}
